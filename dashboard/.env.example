# Govee API Key (required)
GOVEE_API_KEY=your-govee-api-key-here

# Optional: Restrict to specific device IDs (comma-separated)
# GOVEE_ALLOWLIST=device1,device2,device3

# Optional: Dry run mode - no commands sent to devices
# GOVEE_DRY_RUN=true

# Optional: API rate limit (requests per second)
# GOVEE_RATE_RPS=5

# Backend server port
PORT=3001
