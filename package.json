{
  "name": "govee-mcp-server",
  "version": "0.1.0",
  "description": "Secure MCP server for controlling Govee smart lights via natural language. Compatible with Claude Desktop, Claude Code, and all MCP clients.",
  "keywords": [
    "mcp",
    "govee",
    "smart-lights",
    "home-automation",
    "claude",
    "typescript",
    "iot"
  ],
  "type": "module",
  "private": false,
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pino": "^10.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joeynyc/Govee-MCP.git"
  },
  "homepage": "https://github.com/joeynyc/Govee-MCP",
  "bugs": "https://github.com/joeynyc/Govee-MCP/issues",
  "license": "MIT",
  "author": "Joey NYC",
  "engines": {
    "node": ">=20.0.0"
  }
}
